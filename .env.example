# Shrike Configuration

# Database
DATABASE_URL=postgres://shrike:shrike@localhost:5432/shrike?sslmode=disable

# Server
SHRIKE_HOST=0.0.0.0
SHRIKE_PORT=8043

# Crawler
SHRIKE_CRAWLER_WORKERS=10
SHRIKE_CRAWLER_DEFAULT_INTERVAL=30d

# Cache
SHRIKE_CACHE_SIZE=100000
SHRIKE_CACHE_TTL=15m

# API Rate Limits
SHRIKE_RATE_LIMIT_ANONYMOUS=30
SHRIKE_RATE_LIMIT_FREE=300
SHRIKE_RATE_LIMIT_CONTRIBUTOR=1000

# Exports
SHRIKE_EXPORT_DIR=./exports
